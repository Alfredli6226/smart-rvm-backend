{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/dashboard",
      "dest": "/dist/dashboard.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "/dist/dashboard.html"
    },
    {
      "src": "/login",
      "dest": "/dist/index.html"
    },
    {
      "src": "/",
      "dest": "/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "USE_MOCK_DATA": "true"
  }
}