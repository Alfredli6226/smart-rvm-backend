{
  "rewrites": [
    {
      "source": "/api/auth-otp",
      "destination": "/api/auth-otp2"
    },
    {
      "source": "/api/auth-otp2",
      "destination": "/api/auth-otp2"
    },
    {
      "source": "/((?!api/.*|@.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  }
}